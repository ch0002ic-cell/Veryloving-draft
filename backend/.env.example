# Copy to `.env` and adjust. `.env` is git-ignored.
#
#   cp .env.example .env

# Port the HTTP server binds to.
PORT=3000

# HS256 signing secret for JWTs. CHANGE THIS to a long random string outside of
# local development (e.g. `openssl rand -hex 32`).
JWT_SECRET=change_this

# Token lifetimes (seconds). `ACCESS_TTL_SECONDS` is echoed to the client as
# `expires_in`; the app refreshes shortly before it elapses.
ACCESS_TTL_SECONDS=3600
REFRESH_TTL_SECONDS=2592000

# Persist the in-memory store to data/db.json between restarts. Set to false to
# run purely in-memory.
PERSIST=true
# DATA_FILE=./data/db.json

# bcrypt cost factor for password hashing.
BCRYPT_ROUNDS=10
