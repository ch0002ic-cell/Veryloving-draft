NODE_ENV=development
PORT=8787
# Required by the full container WebSocket gateway. The Vercel HTTP-only
# Function reads shared configuration but does not require or validate these
# values as gateway startup requirements.
HUME_API_KEY=
HUME_CONFIG_ID=
HUME_ALLOWED_VOICE_IDS=
# Server-owned mapping from stable app persona IDs to approved Hume UUIDs,
# e.g. {"capybara":{"voice_id":"<uuid>","instructions":"soft, calm, grounding"}}.
HUME_PERSONA_MAP_JSON=
HUME_DEFAULT_PERSONA_ID=capybara
# Keep false until resumed chat-group IDs are bound to an authenticated owner.
HUME_ALLOW_CLIENT_RESUME=false
# Required only when this deployment serves Hume's /chat/completions calls.
# Without it the HTTP route remains available but fails closed with HTTP 503.
HUME_CLM_BEARER_TOKEN=

# First-party mobile sessions. Generate SESSION_JWT_SECRET from at least 32
# cryptographically random bytes; do not reuse any Hume or provider secret.
AUTH_EXCHANGE_ENABLED=false
SESSION_JWT_SECRET=
SESSION_JWT_ISSUER=https://api.veryloving.ai
SESSION_JWT_AUDIENCE=veryloving-mobile
SESSION_JWT_TTL_SECONDS=3600
SESSION_REFRESH_TTL_SECONDS=2592000
APPLE_CLIENT_IDS=
# Google ID token `aud` values (usually web/server client IDs) are distinct
# from permitted `azp` values (native iOS/Android OAuth client IDs).
GOOGLE_TOKEN_AUDIENCES=
GOOGLE_AUTHORIZED_PARTIES=

# Twilio Verify phone authentication. The challenge secret signs five-minute
# app challenges and must be independent of SESSION_JWT_SECRET.
PHONE_AUTH_ENABLED=false
PHONE_AUTH_CHALLENGE_SECRET=
# Keep this stable across JWT-key rotation or phone users will receive new IDs.
PHONE_AUTH_SUBJECT_SECRET=
PHONE_AUTH_CHALLENGE_TTL_SECONDS=300
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# DynamoDB safety API. The table uses string partition/sort keys named PK/SK.
SAFETY_API_ENABLED=false
SAFETY_TABLE_NAME=
AUTH_SESSION_TABLE_NAME=
SAFETY_RETENTION_DAYS=30
AWS_REGION=ap-southeast-1

# Dual-device action routing and robot identity binding. Keep all values in
# the server secret manager. The private value is base64url PKCS8 DER (or PEM);
# the public value is the matching 32-byte raw Ed25519 key in base64url form.
ACTION_SIGNING_PRIVATE_KEY=
ACTION_SIGNING_PUBLIC_KEY=
# Independent HMAC key used to issue a stable, account-bound possession token
# when an interrupted pairing retries the same one-time manufacturer QR code.
ROBOT_PAIRING_TOKEN_SECRET=
# Required for the current long-lived production gateway. The outbox and ACK
# are durable, but same-device queue ownership is not yet a distributed lease.
ACTION_GATEWAY_SINGLE_REPLICA=false
# Server-owned base64 GATT payloads. Never accept these bytes from model tools.
WEARABLE_COMMAND_PAYLOADS_JSON={"deploy_barrier":"","emit_alarm":"","trigger_sos":"","stop":""}
MANUFACTURER_WEBHOOK_URL=
MANUFACTURER_PAIRING_VERIFY_URL=
MANUFACTURER_STATUS_URL=
MANUFACTURER_RESET_URL=
MANUFACTURER_PRIVACY_EXPORT_URL=
MANUFACTURER_PRIVACY_DELETE_URL=
MANUFACTURER_API_KEY=

# Vendor HAL prototypes. These are server-only bridge settings; none may use
# EXPO_PUBLIC_. Both adapters can be enabled simultaneously. These URLs are
# Veryloving-owned provisional contracts, not claimed manufacturer APIs.
# Production requires HTTPS and secret-manager values of at least 32 chars.
YONGYIDA_ADAPTER_ENABLED=false
YONGYIDA_ADAPTER_ID=yongyida-cloud
YONGYIDA_BRIDGE_URL=
YONGYIDA_BRIDGE_API_KEY=
YONGYIDA_CALLBACK_API_KEY=
YONGYIDA_PAIRING_VERIFY_URL=
YONGYIDA_RESET_URL=
YONGYIDA_PRIVACY_EXPORT_URL=
YONGYIDA_PRIVACY_DELETE_URL=
JIANGZHI_ADAPTER_ENABLED=false
JIANGZHI_ADAPTER_ID=jiangzhi-edge
JIANGZHI_BRIDGE_URL=
JIANGZHI_BRIDGE_API_KEY=
JIANGZHI_CALLBACK_API_KEY=
JIANGZHI_PAIRING_VERIFY_URL=
JIANGZHI_RESET_URL=
JIANGZHI_PRIVACY_EXPORT_URL=
JIANGZHI_PRIVACY_DELETE_URL=
ROBOT_ADAPTER_TIMEOUT_MS=5000
ROBOT_ADAPTER_MAX_ATTEMPTS=3
ROBOT_ADAPTER_RETRY_BASE_MS=100
ROBOT_ADAPTER_RETRY_MAX_MS=2000
# Test/local loopback only. Production configuration rejects plain HTTP.
ROBOT_ADAPTER_ALLOW_INSECURE_HTTP=false
DEVICE_TABLE_NAME=
ACTION_OUTBOX_USER_INDEX_NAME=
# GSI for durable factory-reset recovery. Partition key: resetRecoveryPk
# (String); sort key: resetRecoveryAt (Number). Required for production robot
# routing; the table-scan fallback is limited to tests/migrations.
ROBOT_RESET_RECOVERY_INDEX_NAME=
ACTION_REQUEST_TIMEOUT_MS=5000
ROBOT_ACK_TIMEOUT_MS=30000
WEARABLE_ACK_TIMEOUT_MS=5000

# Optional external verification fallback for non-safety endpoints only.
APP_AUTH_VERIFY_URL=

CLM_UPSTREAM_URL=
CLM_UPSTREAM_API_KEY=
CLM_UPSTREAM_MODEL=
CLM_UPSTREAM_TIMEOUT_MS=25000
