NODE_ENV=development
PORT=8787
HUME_API_KEY=
HUME_CLM_BEARER_TOKEN=
HUME_CONFIG_ID=
HUME_ALLOWED_VOICE_IDS=
# Keep false until resumed chat-group IDs are bound to an authenticated owner.
HUME_ALLOW_CLIENT_RESUME=false

# First-party mobile sessions. Generate SESSION_JWT_SECRET from at least 32
# cryptographically random bytes; do not reuse any Hume or provider secret.
AUTH_EXCHANGE_ENABLED=false
SESSION_JWT_SECRET=
SESSION_JWT_ISSUER=https://api.veryloving.ai
SESSION_JWT_AUDIENCE=veryloving-mobile
SESSION_JWT_TTL_SECONDS=3600
SESSION_REFRESH_TTL_SECONDS=2592000
APPLE_CLIENT_IDS=
GOOGLE_CLIENT_IDS=

# DynamoDB safety API. The table uses string partition/sort keys named PK/SK.
SAFETY_API_ENABLED=false
SAFETY_TABLE_NAME=
SAFETY_RETENTION_DAYS=30
AWS_REGION=ap-southeast-1

# Optional legacy verification fallback for non-safety endpoints only.
APP_AUTH_VERIFY_URL=
# Development only; must be empty in production.
DEV_APP_TOKEN=

CLM_UPSTREAM_URL=
CLM_UPSTREAM_API_KEY=
CLM_UPSTREAM_MODEL=
CLM_UPSTREAM_TIMEOUT_MS=25000
