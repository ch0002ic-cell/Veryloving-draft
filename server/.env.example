NODE_ENV=development
PORT=8787
# Required by the full container WebSocket gateway. The Vercel HTTP-only
# Function reads shared configuration but does not require or validate these
# values as gateway startup requirements.
HUME_API_KEY=
HUME_CONFIG_ID=
HUME_ALLOWED_VOICE_IDS=
# Server-owned mapping from stable app persona IDs to approved Hume UUIDs,
# e.g. {"capybara":{"voice_id":"<uuid>","instructions":"soft, calm, grounding"}}.
HUME_PERSONA_MAP_JSON=
HUME_DEFAULT_PERSONA_ID=capybara
# Keep false until resumed chat-group IDs are bound to an authenticated owner.
HUME_ALLOW_CLIENT_RESUME=false
# Required only when this deployment serves Hume's /chat/completions calls.
# Without it the HTTP route remains available but fails closed with HTTP 503.
HUME_CLM_BEARER_TOKEN=
# Operator-only inputs for `npm run provision:hume`. Keep these values in the
# server/operator secret environment; they are never exposed to Expo. IDs must
# be canonical Hume UUIDs and the CLM URL must be HTTPS and end in
# /chat/completions. HUME_VOICE_NAME is used only when no custom voice ID is set.
HUME_CLM_URL=
HUME_TOOL_ID=
HUME_CUSTOM_VOICE_ID=
HUME_VOICE_NAME=

# First-party mobile sessions. Generate SESSION_JWT_SECRET from at least 32
# cryptographically random bytes; do not reuse any Hume or provider secret.
AUTH_EXCHANGE_ENABLED=false
SESSION_JWT_SECRET=
SESSION_JWT_ISSUER=https://api.veryloving.ai
SESSION_JWT_AUDIENCE=veryloving-mobile
# Safe integer bounds: access 300..86400 seconds; refresh 86400..7776000.
SESSION_JWT_TTL_SECONDS=3600
SESSION_REFRESH_TTL_SECONDS=2592000
APPLE_CLIENT_IDS=
# Google ID token `aud` values (usually web/server client IDs) are distinct
# from permitted `azp` values (native iOS/Android OAuth client IDs).
GOOGLE_TOKEN_AUDIENCES=
GOOGLE_AUTHORIZED_PARTIES=

# Twilio Verify phone authentication. The challenge secret signs five-minute
# app challenges and must be independent of SESSION_JWT_SECRET.
PHONE_AUTH_ENABLED=false
PHONE_AUTH_CHALLENGE_SECRET=
# Keep this stable across JWT-key rotation or phone users will receive new IDs.
PHONE_AUTH_SUBJECT_SECRET=
# Safe integer bound: 60..600 seconds.
PHONE_AUTH_CHALLENGE_TTL_SECONDS=300
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# DynamoDB safety API. The table uses string partition/sort keys named PK/SK.
SAFETY_API_ENABLED=false
SAFETY_TABLE_NAME=
AUTH_SESSION_TABLE_NAME=
# Safe integer bound: 1..365 days.
SAFETY_RETENTION_DAYS=30
AWS_REGION=ap-southeast-1

# AI-native cross-device orchestration. Enabling this flag requires the host
# application to inject createAINativeSystem(...) with durable encrypted state,
# scenario repositories, notification/SMS/Hume providers, privacy erasure, and
# the four authenticated device/scheduler binding resolvers documented in
# docs/final-handoff-confirmation.md#ai-native-integration-guide. Secrets stay in the server secret manager.
AI_NATIVE_ENABLED=false
# Keep this true after an environment has ever stored AI-native state or
# memories, even when runtime orchestration is temporarily disabled. It keeps
# those durable records inside account export/deletion. Runtime enablement
# requires this lifecycle gate.
AI_NATIVE_DATA_LIFECYCLE_ENABLED=false
# Required in production until distributed scenario-admission leases replace
# the process-local critical/standard/background scheduler.
AI_NATIVE_SINGLE_REPLICA=false
# Production only: absolute path inside the immutable deployment image to a
# reviewed CommonJS module exporting createAINativeProductionDependencies.
# The versioned composition contract rejects demo/in-memory repositories,
# requires a rotation-safe external keyring, provider/privacy capabilities,
# and all four authenticated trust hooks before the listener can bind.
AI_NATIVE_PRODUCTION_MODULE=
# Development-only fixed account used by the in-memory dashboard runtime. The
# local scenario endpoint never accepts an arbitrary account identity.
AI_NATIVE_DEMO_USER_ID=test-user-1

# Dual-device action routing and robot identity binding. Keep all values in
# the server secret manager. The private value is base64url PKCS8 DER (or PEM);
# the public value is the matching 32-byte raw Ed25519 key in base64url form.
ACTION_SIGNING_PRIVATE_KEY=
ACTION_SIGNING_PUBLIC_KEY=
# Independent HMAC key used to issue a stable, account-bound possession token
# when an interrupted pairing retries the same one-time manufacturer QR code.
ROBOT_PAIRING_TOKEN_SECRET=
# Required for the current long-lived production gateway. The outbox and ACK
# are durable, but same-device queue ownership is not yet a distributed lease.
ACTION_GATEWAY_SINGLE_REPLICA=false
# Server-owned base64 GATT payloads. Never accept these bytes from model tools.
WEARABLE_COMMAND_PAYLOADS_JSON={"deploy_barrier":"","emit_alarm":"","trigger_sos":"","stop":""}
MANUFACTURER_WEBHOOK_URL=
MANUFACTURER_PAIRING_VERIFY_URL=
MANUFACTURER_STATUS_URL=
MANUFACTURER_RESET_URL=
MANUFACTURER_PRIVACY_EXPORT_URL=
MANUFACTURER_PRIVACY_DELETE_URL=
MANUFACTURER_API_KEY=

# Vendor HAL prototypes. These are server-only bridge settings; none may use
# EXPO_PUBLIC_. Both adapters can be enabled simultaneously. These URLs are
# Veryloving-owned provisional contracts, not claimed manufacturer APIs.
# Production requires HTTPS and secret-manager values of at least 32 chars.
# Development/test only: this loopback origin overrides both bridge URLs.
# Production, non-loopback, path, query, and credential-bearing values fail.
MOCK_MANUFACTURER_URL=
MOCK_MANUFACTURER_PORT=3001
MOCK_MANUFACTURER_LATENCY_MIN_MS=50
MOCK_MANUFACTURER_LATENCY_MAX_MS=200
MOCK_MANUFACTURER_FAILURE_RATE=0.05
MOCK_MANUFACTURER_TELEMETRY_INTERVAL_MS=1000
MOCK_MANUFACTURER_SEED=1447833650
# Synthetic dual-device event controls. Probabilities are per emitted frame;
# medication reminders use a deterministic robot telemetry tick interval.
MOCK_MANUFACTURER_FALL_EVENT_RATE=0.001
MOCK_MANUFACTURER_STRESS_EVENT_RATE=0.01
MOCK_MANUFACTURER_MEDICATION_REMINDER_EVERY_TICKS=3600
MOCK_MANUFACTURER_MAX_SIMULATED_DEVICES=100
# Optional simulator-only placeholder. When MOCK_MANUFACTURER_URL is set, the
# runtime uses this dedicated value instead of either vendor bridge key. It
# must differ from every configured vendor credential.
MOCK_MANUFACTURER_API_KEY=
MOCK_MANUFACTURER_MAX_REQUEST_BYTES=65536
MOCK_MANUFACTURER_REQUEST_TIMEOUT_MS=5000
MOCK_MANUFACTURER_MAX_QUEUE_KEYS=1000
MOCK_MANUFACTURER_MAX_QUEUED_COMMANDS_TOTAL=5000
MOCK_MANUFACTURER_MAX_CONNECTIONS=100
MOCK_MANUFACTURER_MAX_CONCURRENT_REQUESTS=200
MOCK_MANUFACTURER_MAX_TELEMETRY_STREAMS=25
MOCK_MANUFACTURER_MAX_DASHBOARD_STREAMS=25
# Optional asynchronous-ACK callback used by the loopback integration test.
# The URL must target the local Veryloving server callback route. Callback
# credentials are the adapter-specific YONGYIDA_CALLBACK_API_KEY and
# JIANGZHI_CALLBACK_API_KEY values declared below; never put a credential in
# the URL.
MOCK_MANUFACTURER_ACK_CALLBACK_URL=
MOCK_MANUFACTURER_ACK_DELAY_MS=25
MOCK_MANUFACTURER_ACK_TIMEOUT_MS=2000
MOCK_MANUFACTURER_ACK_MAX_REQUEST_BYTES=4096
MOCK_MANUFACTURER_ACK_MAX_RESPONSE_BYTES=4096
# Loopback-only main server proxied by the simulator dashboard. The browser
# never receives backend credentials and cannot select another upstream.
MOCK_MAIN_SERVER_URL=http://127.0.0.1:8787
MOCK_MAIN_SERVER_TIMEOUT_MS=5000
MOCK_MAIN_SERVER_MAX_RESPONSE_BYTES=65536
YONGYIDA_ADAPTER_ENABLED=false
YONGYIDA_ADAPTER_ID=yongyida-cloud
YONGYIDA_BRIDGE_URL=
YONGYIDA_BRIDGE_API_KEY=
YONGYIDA_CALLBACK_API_KEY=
YONGYIDA_PAIRING_VERIFY_URL=
YONGYIDA_RESET_URL=
YONGYIDA_PRIVACY_EXPORT_URL=
YONGYIDA_PRIVACY_DELETE_URL=
JIANGZHI_ADAPTER_ENABLED=false
JIANGZHI_ADAPTER_ID=jiangzhi-edge
JIANGZHI_BRIDGE_URL=
JIANGZHI_BRIDGE_API_KEY=
JIANGZHI_CALLBACK_API_KEY=
JIANGZHI_PAIRING_VERIFY_URL=
JIANGZHI_RESET_URL=
JIANGZHI_PRIVACY_EXPORT_URL=
JIANGZHI_PRIVACY_DELETE_URL=
ROBOT_ADAPTER_TIMEOUT_MS=5000
ROBOT_ADAPTER_MAX_ATTEMPTS=3
ROBOT_ADAPTER_RETRY_BASE_MS=100
ROBOT_ADAPTER_RETRY_MAX_MS=2000
# Test/local loopback only. Production configuration rejects plain HTTP.
ROBOT_ADAPTER_ALLOW_INSECURE_HTTP=false
DEVICE_TABLE_NAME=
ACTION_OUTBOX_USER_INDEX_NAME=
# GSI for durable factory-reset recovery. Partition key: resetRecoveryPk
# (String); sort key: resetRecoveryAt (Number). Required for production robot
# routing; the table-scan fallback is limited to tests/migrations.
ROBOT_RESET_RECOVERY_INDEX_NAME=
# Startup rejects fractional, unsafe, or out-of-range values. Bounds:
# request 1..120000 ms; robot ACK 1..300000 ms; wearable ACK 1..60000 ms.
ACTION_REQUEST_TIMEOUT_MS=5000
ROBOT_ACK_TIMEOUT_MS=30000
WEARABLE_ACK_TIMEOUT_MS=5000

# Optional external verification fallback for non-safety endpoints only.
APP_AUTH_VERIFY_URL=

CLM_UPSTREAM_URL=
CLM_UPSTREAM_API_KEY=
CLM_UPSTREAM_MODEL=
# Safe integer bound: 1..30000 ms (below the HTTP server request deadline).
CLM_UPSTREAM_TIMEOUT_MS=25000

# Test-only adapter soak controls. CI defaults to a short bounded run; an
# approved reliability runner may raise the duration up to 24 hours. The heap
# growth allowance is bounded to 1 MiB..512 MiB.
ROBOT_SOAK_DURATION_MS=60000
ROBOT_SOAK_MAX_HEAP_GROWTH_BYTES=33554432
