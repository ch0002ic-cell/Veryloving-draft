{
  "name": "veryloving-clm-server",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": "24.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.adapters.json && tsc -p tsconfig.ai-native.json",
    "build:mocks": "tsc -p tsconfig.mocks.json",
    "typecheck": "tsc -p tsconfig.adapters.json --noEmit && tsc -p tsconfig.ai-native.json --noEmit && tsc -p tsconfig.mocks.json --noEmit && tsc -p tsconfig.tests.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1093.0",
    "@aws-sdk/lib-dynamodb": "^3.1093.0",
    "ws": "8.21.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.3",
    "typescript": "~7.0.2"
  }
}
