{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "rootDir": ".",
    "strict": true,
    "noEmit": true,
    "noEmitOnError": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "types": ["node", "jest"]
  },
  "include": [
    "src/**/*.ts",
    "mocks/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "dist/**",
    "dist-ai-native/**",
    "dist-mocks/**"
  ]
}
