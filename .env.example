# Copy this file to .env, keep it uncommitted, then run `npm run validate-env`.
# See SETUP.md for provider dashboards, ownership, and production requirements.
# Every EXPO_PUBLIC_* value is embedded in the client and must be treated as
# public. Empty means unconfigured; feature flags default safely to false.
# Keep this reference complete. In a real .env, optional unset assignments may
# be omitted; `npm run validate-env` reports the resulting feature gates.

# Mobile API and authentication
# HTTPS root of the deployed API. For the HTTP-only Vercel adapter this is
# https://<project>.vercel.app after its auth/safety probes pass. Do not point
# the Hume WebSocket variable at this domain.
EXPO_PUBLIC_API_BASE_URL=
# OAuth Web application client ID. Google ID tokens use this public ID as the
# backend audience; keep server GOOGLE_TOKEN_AUDIENCES in sync.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# OAuth iOS application client ID for bundle com.veryloving.app. Its reversed
# value becomes the native callback scheme. Changing it requires regenerating
# and reinstalling the native iOS development build; a Metro reload is not
# sufficient. Sign in with Apple needs no mobile environment variable: its
# audience is the same iOS bundle identifier. Keep this public ID in server
# GOOGLE_AUTHORIZED_PARTIES when it appears in `azp`.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Enable only when the deployed API has PHONE_AUTH_ENABLED=true and a verified
# Twilio Verify configuration. This prevents consuming SMS attempts against an
# intentionally disabled backend.
EXPO_PUBLIC_PHONE_AUTH_ENABLED=false

# Voice AI
# These URLs are outputs of deploying VeryLoving services, not Hume-issued
# credentials. The WebSocket gateway requires a long-lived host with TLS and
# upgrade support; the customization root may equal the HTTP API base.
EXPO_PUBLIC_HUME_WS_PROXY_URL=
# Hume configuration and branded-voice IDs must be canonical UUIDs.
EXPO_PUBLIC_HUME_CONFIG_ID=
EXPO_PUBLIC_HUME_CUSTOMIZATION_URL=
EXPO_PUBLIC_HUME_CLM_ENABLED=false
EXPO_PUBLIC_HUME_BRANDED_VOICE_ID=
# Development only. Never set a direct Hume key in preview or production.
EXPO_PUBLIC_HUME_API_KEY=

# Maps, resilience, and safety backend
# Use a Mapbox public pk.* runtime token here. The secret downloads token is a
# separate build-only variable below.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Forces the offline voice path for fault testing; keep false for production.
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=false
# Enable only after the account-backed contacts/SOS/privacy API passes probes.
EXPO_PUBLIC_SAFETY_BACKEND_ENABLED=false

# VL01 wearable
# Enable only with UUIDs approved by the VL01 firmware owner. Production
# pairing fails closed when the protocol is enabled but incomplete.
EXPO_PUBLIC_VL01_ENABLED=false
EXPO_PUBLIC_VL01_SERVICE_UUID=
EXPO_PUBLIC_VL01_BATTERY_CHARACTERISTIC_UUID=
EXPO_PUBLIC_VL01_STATUS_CHARACTERISTIC_UUID=
EXPO_PUBLIC_VL01_EVENT_CHARACTERISTIC_UUID=
EXPO_PUBLIC_VL01_COMMAND_CHARACTERISTIC_UUID=

# Native build secret
# Native dependency download credential. Store as a secret locally/EAS; it is
# not bundled into the app because it does not use the EXPO_PUBLIC_ prefix.
# It must be a Mapbox sk.* token with only downloads:read.
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=

# Build diagnostics (not credentials)
# EAS sets these per profile. Local validation accepts development, preview,
# or production and never prints configured values.
VERYLOVING_BUILD_PROFILE=development
VERYLOVING_CONFIG_DIAGNOSTICS=0
