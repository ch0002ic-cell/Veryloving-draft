// Secrets.example.xcconfig
// Copy this file to "Secrets.xcconfig" (git-ignored) and fill in real values.
// When VL_API_HOST is empty, the app runs on in-memory MOCK services.
//
//   cp Config/Secrets.example.xcconfig Config/Secrets.xcconfig
//
// Then point at your backend (host only — no scheme, no "//"):

VL_API_HOST = api.veryloving.ai
VL_API_SCHEME = https

// Other secrets are NOT build-time values — they belong elsewhere:
//   • Hume API key       → entered at runtime, stored in Keychain
//   • Firebase           → add GoogleService-Info.plist (also git-ignored)
//   • APNs / Twilio      → live on the backend, never in the app
