{
  "name": "veryloving-expo-rebuild",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "doctor": "npx expo-doctor",
    "lint": "eslint .",
    "test": "npm run build:adapters && npm run typecheck:manufacturer-mock && npm run build:ai-native && npm run test:core && npm run test:adapters && npm run test:integration:adapters && npm run test:ai-native",
    "test:core": "node --require @babel/register --test tests/*.test.cjs server/*.test.cjs",
    "test:adapters": "jest --config jest.adapters.config.cjs --runInBand --coverage",
    "test:manufacturer-mock": "jest --config jest.adapters.config.cjs --runInBand --coverage=false --runTestsByPath server/mocks/__tests__/ManufacturerMockServer.test.ts",
    "test:integration:adapters": "NODE_ENV=test node --test tests/integration/manufacturer-bridge.test.cjs",
    "test:ai-native": "jest --config jest.ai-native.config.cjs --runInBand --coverage",
    "test:soak:adapters": "npm run build:adapters && node --expose-gc tests/integration/robot-adapter-soak.cjs",
    "typecheck:adapters": "tsc -p server/tsconfig.adapters.json --noEmit",
    "typecheck:manufacturer-mock": "tsc -p server/tsconfig.mocks.json --noEmit",
    "typecheck:ai-native": "tsc -p server/tsconfig.ai-native.json --noEmit",
    "build:adapters": "tsc -p server/tsconfig.adapters.json",
    "build:manufacturer-mock": "tsc -p server/tsconfig.mocks.json",
    "build:ai-native": "tsc -p server/tsconfig.ai-native.json",
    "mock:manufacturer": "npm run build:manufacturer-mock && node server/dist-mocks/mocks/ManufacturerMockServer.js",
    "validate-env": "node scripts/validate-env.cjs",
    "validate": "node scripts/validate.cjs",
    "clm:start": "npm run build:adapters && npm run build:ai-native && node server/clm-server.cjs",
    "hume:provision": "node scripts/provision-hume.mjs",
    "hume:voice:generate": "node scripts/design-hume-voice.mjs generate",
    "hume:voice:save": "node scripts/design-hume-voice.mjs save"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^15.0.0",
    "@rnmapbox/maps": "^10.2.7",
    "expo": "~57.0.7",
    "expo-apple-authentication": "~57.0.1",
    "expo-application": "~57.0.2",
    "expo-asset": "~57.0.6",
    "expo-audio": "~57.0.2",
    "expo-camera": "~57.0.3",
    "expo-constants": "~57.0.6",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.7",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-localization": "~57.0.1",
    "expo-location": "~57.0.5",
    "expo-network": "~57.0.1",
    "expo-notifications": "~57.0.6",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-sharing": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "i18n-js": "^4.5.3",
    "libphonenumber-js": "^1.13.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-ble-plx": "^3.5.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.10.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/register": "^7.29.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.20.1",
    "babel-jest": "^29.7.0",
    "eslint": "^9.0.0",
    "jest": "~29.7.0",
    "react-native-codegen": "^0.70.7",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "xcode": {
      "uuid": "11.1.1"
    }
  }
}
