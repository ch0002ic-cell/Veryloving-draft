{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "noUncheckedIndexedAccess": true
  },
  "include": [
    "app/**/*.js",
    "src/**/*.js",
    "plugins/**/*.js",
    "app.config.js",
    "babel.config.js",
    "eslint.config.js"
  ],
  "exclude": [
    "node_modules",
    "server",
    "tests",
    "scripts"
  ]
}
