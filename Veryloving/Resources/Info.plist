<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Veryloving</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- Backend base URL, composed from xcconfig (Config/*.xcconfig). Empty host
	     (the default) → the app runs on mock services. See AppConfig. -->
	<key>VL_API_BASE_URL</key>
	<string>$(VL_API_SCHEME)://$(VL_API_HOST)</string>

	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>BrandPrimary</string>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- Permission usage strings (required or the app is rejected at submission). -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Veryloving uses your microphone so you can talk with your AI companion.</string>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Veryloving connects to your jewelry over Bluetooth to receive SOS triggers and battery status.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Veryloving shares your location with your emergency contacts when you trigger an SOS.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Veryloving keeps sharing your location with emergency contacts for a short time after an SOS, even in the background.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Veryloving uses Face ID to keep your account and emergency contacts secure.</string>
	<key>NSContactsUsageDescription</key>
	<string>Veryloving can import contacts to make adding emergency contacts faster.</string>

	<!-- Background execution modes the Guardian features rely on. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>bluetooth-central</string>
		<string>location</string>
		<string>remote-notification</string>
	</array>
</dict>
</plist>
